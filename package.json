{
  "name": "bobkat-stackscore",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "prisma generate && next build --turbopack",
    "vercel-build": "node scripts/vercel-build.mjs",
