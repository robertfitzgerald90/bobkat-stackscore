    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "^3.9.0",
    "resend": "^6.17.2",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
