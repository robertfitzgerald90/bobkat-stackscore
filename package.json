    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsx scripts/smoke-check.ts",
    "merge:recommendations": "tsx scripts/merge-duplicate-recommendations.ts",
    "cleanup:test-data": "tsx scripts/cleanup-test-customer-data.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:setup": "prisma migrate deploy && prisma db seed",
    "db:neon:setup": "prisma migrate deploy && prisma db seed",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
