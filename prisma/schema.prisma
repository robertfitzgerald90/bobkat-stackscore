generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  technician
  client
}

enum ClientStatus {
  prospect
  active
  inactive
  archived
}

enum ComplianceFramework {
  none
  cmmc
  nist_800_171
  iso_27001
  hipaa
  pci_dss
  sox
  other
}

enum PrimaryBusinessGoal {
  improve_cybersecurity
  reduce_downtime
  support_growth
  increase_productivity
  improve_compliance
  standardize_technology
  reduce_it_costs
  modernize_infrastructure
  other
}

enum ItSupportModel {
  internal
  msp
  hybrid
  none
}

enum EnvironmentType {
  cloud
  hybrid
  on_premises
}

enum AssessmentType {
  initial
  quarterly
  annual
  followup
}

enum AssessmentStatus {
  draft
  completed
  archived
}

enum ScoringEngineVersion {
  v1
  v2
}

enum RiskLevel {
  low
  medium
  high
  critical
}

enum Priority {
  low
  medium
  high
  critical
}

enum RecommendationStatus {
  open
  accepted
  in_progress
  completed
  deferred
  declined
  archived
}

enum ProjectStatus {
  proposed
  approved
  scheduled
  in_progress
  completed
  cancelled
}

enum Rating {
  exceptional
  strong
  stable
  at_risk
  critical
}

enum ResponseType {
  binary
  ternary
  maturity
}

enum MaturityTier {
  nascent
  foundational
  developing
  mature
  optimized
}

enum TrendDirection {
  improving
  stable
  declining
}

enum ProfileSnapshotTrigger {
  assessment_completed
  project_completed
  scheduled_review
  manual
}

enum DocumentType {
  report
  diagram
  contract
  proposal
  evidence
  technology_improvement_plan
  quarterly_business_review
  other
}

enum QuarterlyBusinessReviewStatus {
  draft
  generated
}

enum TechnologyImprovementPlanStatus {
  draft
  generated
  superseded
}

enum TipWorkflowStep {
  profile
  recommendations
  playbooks
  investment
  roadmap
  preview
  complete
}

enum NoteType {
  general
  assessment
  recommendation
  project
  system
}

enum Visibility {
  internal
  client_visible
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(technician)
  isActive     Boolean  @default(true)
  clientId     String?  @unique
  invitedAt    DateTime?
  onboardingCompletedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client                 Client?                  @relation(fields: [clientId], references: [id])
  assessments            Assessment[]             @relation("AssessorAssessments")
  recommendationsCreated AssessmentRecommendation[] @relation("RecommendationCreator")
  projectsAssigned       Project[]                @relation("ProjectAssignee")
  documentsUploaded      Document[]
  notes                  Note[]
  improvementPlansCreated TechnologyImprovementPlan[]
  quarterlyBusinessReviewsCreated QuarterlyBusinessReview[]
  purchases              AssessmentPurchase[]
  activationTokens       AccountActivationToken[]
  communicationTestSends CommunicationTestSend[]
  communicationBrandSettingsUpdates CommunicationBrandSettings[]
  communicationTemplateVersionsPublished CommunicationTemplateVersion[] @relation("PublishedTemplateVersions")
  communicationTemplateVersionsCreated CommunicationTemplateVersion[] @relation("CreatedTemplateVersions")
  communicationSampleProfiles CommunicationSampleProfile[]
}

model Client {
  id                        String               @id @default(uuid())
  companyName               String
  primaryContactName        String
  primaryContactEmail       String
  primaryContactPhone       String?
  primaryContactTitle       String?
  industry                  String?
  employeeCount             Int?
  numberOfLocations         Int?
  deviceCount               Int?
  primaryBusinessGoal       PrimaryBusinessGoal?
  highestTechnologyPriority String?
  technologyVision          String?              @db.Text
  complianceFramework       ComplianceFramework? @default(none)
  complianceDetails         Json?
  itSupportModel            ItSupportModel?
  environmentType           EnvironmentType?
  locationCity              String?
  locationState             String?
  status                    ClientStatus         @default(prospect)
  notes                     String?              @db.Text
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  assessments     Assessment[]
  recommendations AssessmentRecommendation[]
  projects        Project[]
  scoreHistory       ClientScoreHistory[]
  documents          Document[]
  activityNotes      Note[]
  technologyProfile  TechnologyProfile?
  profileSnapshots   TechnologyProfileSnapshot[]
  improvementPlans   TechnologyImprovementPlan[]
  quarterlyBusinessReviews QuarterlyBusinessReview[]
  users              User[]
  purchases          AssessmentPurchase[]
  clientTechnologies ClientTechnology[]
}

model AssessmentCategory {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  description   String?  @db.Text
  maxPoints     Int
  displayOrder  Int
  v2CategoryCode String?
  v2DisplayName  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  questions       AssessmentQuestion[]
  categoryScores  AssessmentCategoryScore[]
  recommendations AssessmentRecommendation[]
  templates       RecommendationTemplate[]
  projects        Project[]
}

model AssessmentQuestion {
  id                 String       @id @default(uuid())
  code               String       @unique
  v2QuestionId       String?      @unique
  categoryId         String
  questionText       String       @db.Text
  helpText           String?      @db.Text
  purpose            String?      @db.Text
  capability         String?
  responseType       ResponseType @default(ternary)
  evidenceRequired   String?      @db.Text
  relatedService     String?
  relatedPlaybook    String?
  relatedTechnologies String[]    @default([])
  adminNotes         String?      @db.Text
  weight             Int
  displayOrder       Int
  riskLevel          RiskLevel    @default(medium)
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  category      AssessmentCategory   @relation(fields: [categoryId], references: [id])
  answerOptions AnswerOption[]
  responses     AssessmentResponse[]
}

model AnswerOption {
  id                       String   @id @default(uuid())
  questionId               String
  answerText               String
  scoreValue               Int
  displayOrder             Int
  triggersRecommendation   Boolean  @default(false)
  triggersCriticalFlag     Boolean  @default(false)
  recommendationTemplateId String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  question               AssessmentQuestion      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  recommendationTemplate RecommendationTemplate? @relation(fields: [recommendationTemplateId], references: [id])
  responses              AssessmentResponse[]
}

model Assessment {
  id                  String                @id @default(uuid())
  clientId            String
  assessorUserId      String
  assessmentName      String
  assessmentType      AssessmentType
  status              AssessmentStatus      @default(draft)
  scoringEngineVersion ScoringEngineVersion @default(v2)
  assessmentDate      DateTime
  overallScore        Decimal?         @db.Decimal(5, 2)
  securityScore       Decimal?         @db.Decimal(5, 2)
  backupScore         Decimal?         @db.Decimal(5, 2)
  infrastructureScore Decimal?         @db.Decimal(5, 2)
  endpointScore       Decimal?         @db.Decimal(5, 2)
  documentationScore  Decimal?         @db.Decimal(5, 2)
  bcdrScore           Decimal?         @db.Decimal(5, 2)
  strategicScore      Decimal?         @db.Decimal(5, 2)
  hasCriticalExposure Boolean          @default(false)
  executiveSummary    String?          @db.Text
  internalNotes       String?          @db.Text
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  completedAt         DateTime?
  sourceAssessmentId  String?

  client             Client                    @relation(fields: [clientId], references: [id])
  assessor           User                      @relation("AssessorAssessments", fields: [assessorUserId], references: [id])
  sourceAssessment   Assessment?               @relation("AssessmentReassessment", fields: [sourceAssessmentId], references: [id], onDelete: SetNull)
  derivedAssessments Assessment[]              @relation("AssessmentReassessment")
  responses          AssessmentResponse[]
  categoryScores  AssessmentCategoryScore[]
  recommendations AssessmentRecommendation[]
  latestRecommendations AssessmentRecommendation[] @relation("RecommendationLatestAssessment")
  recommendationTriggers RecommendationAssessmentTrigger[]
  scoreHistory    ClientScoreHistory[]
  documents              Document[]
  notes                  Note[]
  currentForProfiles     TechnologyProfile[]        @relation("ProfileCurrentAssessment")
  profileSnapshots       TechnologyProfileSnapshot[]
  improvementPlans       TechnologyImprovementPlan[]
  purchase               AssessmentPurchase?
}

model TechnologyProfile {
  id                          String          @id @default(uuid())
  clientId                    String          @unique
  overallStackScore           Decimal?        @db.Decimal(5, 2)
  maturityTier                MaturityTier?
  categoryScores              Json?
  riskSummary                 Json?
  currentAssessmentId         String?
  lastAssessedAt              DateTime?
  nextRecommendedAssessmentAt DateTime?
  trendDirection              TrendDirection?
  criticalExposureCount       Int             @default(0)
  openRecommendationCount     Int             @default(0)
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt

  client            Client                      @relation(fields: [clientId], references: [id])
  currentAssessment Assessment?                 @relation("ProfileCurrentAssessment", fields: [currentAssessmentId], references: [id], onDelete: SetNull)
  snapshots         TechnologyProfileSnapshot[]
}

model TechnologyProfileSnapshot {
  id                  String                 @id @default(uuid())
  clientId            String
  technologyProfileId String
  triggerType         ProfileSnapshotTrigger
  triggerAssessmentId String?
  snapshotAt          DateTime
  overallStackScore   Decimal                @db.Decimal(5, 2)
  maturityTier        MaturityTier
  categoryScores      Json
  riskSummary         Json?
  metadata            Json?
  createdAt           DateTime               @default(now())

  client            Client            @relation(fields: [clientId], references: [id])
  technologyProfile TechnologyProfile @relation(fields: [technologyProfileId], references: [id], onDelete: Cascade)
  triggerAssessment Assessment?       @relation(fields: [triggerAssessmentId], references: [id], onDelete: SetNull)
}

model AssessmentResponse {
  id                     String   @id @default(uuid())
  assessmentId           String
  questionId             String
  selectedAnswerOptionId String
  scoreEarned            Int
  notes                  String?  @db.Text
  evidence               String?  @db.Text
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  assessment           Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question             AssessmentQuestion @relation(fields: [questionId], references: [id])
  selectedAnswerOption AnswerOption       @relation(fields: [selectedAnswerOptionId], references: [id])

  @@unique([assessmentId, questionId])
}

model AssessmentCategoryScore {
  id             String   @id @default(uuid())
  assessmentId   String
  categoryId     String
  pointsEarned   Decimal  @db.Decimal(6, 2)
  pointsPossible Decimal  @db.Decimal(6, 2)
  percentScore   Decimal  @db.Decimal(5, 2)
  rating         Rating
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assessment Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  category   AssessmentCategory @relation(fields: [categoryId], references: [id])

  @@unique([assessmentId, categoryId])
}

model RecommendationTemplate {
  id                    String   @id @default(uuid())
  code                  String   @unique
  categoryId            String
  title                 String
  description           String   @db.Text
  businessImpact        String   @db.Text
  suggestedService      String
  priority              Priority
  estimatedImpactPoints Int
  consolidationGroupId  String?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  category      AssessmentCategory @relation(fields: [categoryId], references: [id])
  answerOptions AnswerOption[]
  recommendations AssessmentRecommendation[]
}

model AssessmentRecommendation {
  id                       String               @id @default(uuid())
  assessmentId             String
  clientId                 String
  categoryId               String
  recommendationTemplateId String?
  consolidationGroupId     String?
  dedupeKey                String
  latestAssessmentId       String
  lastTriggeredAt          DateTime             @default(now())
  latestTriggerReason      String?              @db.Text
  triggeredInLatestAssessment Boolean           @default(true)
  isRecurrence             Boolean              @default(false)
  recurrenceCount          Int                  @default(0)
  title                    String
  description              String               @db.Text
  businessImpact           String               @db.Text
  suggestedService         String?
  priority                 Priority
  status                   RecommendationStatus @default(open)
  estimatedImpactPoints    Int
  createdByUserId          String
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  completedAt              DateTime?

  assessment             Assessment              @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  latestAssessment       Assessment              @relation("RecommendationLatestAssessment", fields: [latestAssessmentId], references: [id])
  client                 Client                  @relation(fields: [clientId], references: [id])
  category               AssessmentCategory      @relation(fields: [categoryId], references: [id])
  recommendationTemplate RecommendationTemplate? @relation(fields: [recommendationTemplateId], references: [id])
  createdBy              User                    @relation("RecommendationCreator", fields: [createdByUserId], references: [id])
  project                Project?
  triggers               RecommendationAssessmentTrigger[]

  @@index([clientId, dedupeKey])
}

model RecommendationAssessmentTrigger {
  id               String   @id @default(uuid())
  recommendationId String
  assessmentId     String
  triggeredAt      DateTime @default(now())
  triggerReason    String?  @db.Text

  recommendation AssessmentRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  assessment     Assessment               @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([recommendationId, assessmentId])
  @@index([assessmentId])
}

model Project {
  id                    String        @id @default(uuid())
  clientId              String
  recommendationId      String        @unique
  assignedUserId        String?
  title                 String
  description           String?       @db.Text
  status                ProjectStatus @default(proposed)
  priority              Priority
  categoryId            String
  estimatedImpactPoints Int?
  actualImpactPoints    Int?
  estimatedCost         Decimal?      @db.Decimal(10, 2)
  startDate             DateTime?
  targetCompletionDate  DateTime?
  completedAt           DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  client         Client                    @relation(fields: [clientId], references: [id])
  recommendation AssessmentRecommendation? @relation(fields: [recommendationId], references: [id])
  assignedUser   User?                     @relation("ProjectAssignee", fields: [assignedUserId], references: [id])
  category       AssessmentCategory        @relation(fields: [categoryId], references: [id])
  documents      Document[]
  notes          Note[]
}

model ClientScoreHistory {
  id                  String   @id @default(uuid())
  clientId            String
  assessmentId        String?
  recordedDate        DateTime
  overallScore        Decimal  @db.Decimal(5, 2)
  securityScore       Decimal? @db.Decimal(5, 2)
  backupScore         Decimal? @db.Decimal(5, 2)
  infrastructureScore Decimal? @db.Decimal(5, 2)
  endpointScore       Decimal? @db.Decimal(5, 2)
  documentationScore  Decimal? @db.Decimal(5, 2)
  bcdrScore           Decimal? @db.Decimal(5, 2)
  strategicScore      Decimal? @db.Decimal(5, 2)
  pillarScores        Json?
  notes               String?  @db.Text
  createdAt           DateTime @default(now())

  client     Client      @relation(fields: [clientId], references: [id])
  assessment Assessment? @relation(fields: [assessmentId], references: [id])
}

model Document {
  id               String       @id @default(uuid())
  clientId         String
  assessmentId     String?
  projectId        String?
  tipId            String?      @unique
  qbrId            String?      @unique
  documentType     DocumentType
  title            String
  fileUrl          String
  uploadedByUserId String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  client     Client      @relation(fields: [clientId], references: [id])
  assessment Assessment? @relation(fields: [assessmentId], references: [id])
  project    Project?    @relation(fields: [projectId], references: [id])
  tip        TechnologyImprovementPlan? @relation(fields: [tipId], references: [id])
  quarterlyBusinessReview QuarterlyBusinessReview? @relation(fields: [qbrId], references: [id])
  uploadedBy User        @relation(fields: [uploadedByUserId], references: [id])
}

model TechnologyImprovementPlan {
  id               String                          @id @default(uuid())
  clientId         String
  assessmentId     String?
  status           TechnologyImprovementPlanStatus @default(draft)
  currentStep      TipWorkflowStep                 @default(profile)
  version          Int                             @default(1)
  title            String
  wizardState      Json
  executiveSummary String?                         @db.Text
  generatedAt      DateTime?
  createdByUserId  String
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt

  client     Client      @relation(fields: [clientId], references: [id])
  assessment Assessment? @relation(fields: [assessmentId], references: [id])
  createdBy  User        @relation(fields: [createdByUserId], references: [id])
  document   Document?
}

model QuarterlyBusinessReview {
  id                String                        @id @default(uuid())
  clientId          String
  reviewPeriodStart DateTime
  reviewPeriodEnd   DateTime
  title             String
  status            QuarterlyBusinessReviewStatus @default(draft)
  executiveSummary  String?                       @db.Text
  generatedAt       DateTime?
  createdByUserId   String
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  client    Client    @relation(fields: [clientId], references: [id])
  createdBy User      @relation(fields: [createdByUserId], references: [id])
  document  Document?
}

model Note {
  id           String     @id @default(uuid())
  clientId     String
  assessmentId String?
  projectId    String?
  userId       String
  noteType     NoteType   @default(general)
  visibility   Visibility @default(internal)
  content      String     @db.Text
  createdAt    DateTime   @default(now())

  client     Client      @relation(fields: [clientId], references: [id])
  assessment Assessment? @relation(fields: [assessmentId], references: [id])
  project    Project?    @relation(fields: [projectId], references: [id])
  user       User        @relation(fields: [userId], references: [id])
}

enum PurchaseStatus {
  pending
  fulfilled
  failed
  manual_review
  refunded
}

enum CommunicationTestSendStatus {
  sent
  failed
}

enum CommunicationTemplateVersionStatus {
  draft
  published
  archived
}

enum TechnologyStandardStatus {
  preferred
  approved
  conditional
  existing_environment
  legacy
  prohibited
}

enum TechnologyLifecycleStatus {
  current
  review_required
  end_of_sale
  end_of_support
  replacement_planned
  retired
}

enum TechnologyPillarRelationshipType {
  primary
  supporting
  informational
}

enum ClientTechnologyDeploymentStatus {
  planned
  implementing
  active
  replacing
  retired
}

enum ClientTechnologyAlignmentStatus {
  preferred
  approved
  exception
  legacy
  not_standard
  unassessed
}

enum ClientTechnologyHealthStatus {
  healthy
  attention_needed
  at_risk
  unknown
}

enum ManagedByType {
  bobkat_it
  client
  third_party
  shared
  unknown
}

enum TechnologySnapshotLeadStatus {
  new
  contacted
  assessment_interested
  assessment_purchased
  not_interested
  converted
}

enum SnapshotItManagementModel {
  in_house
  outsourced
  part_time_internal
  none
  unsure
}

model AssessmentPurchase {
  id                    String         @id @default(uuid())
  stripeSessionId       String         @unique
  stripeCustomerId      String?
  stripePaymentIntentId String?
  productType           String
  status                PurchaseStatus @default(pending)
  paymentStatus         String
  amountTotal           Int?
  currency              String?
  purchaserEmail        String
  failureReason         String?        @db.Text
  clientId              String?
  userId                String?
  assessmentId          String?        @unique
  fulfilledAt           DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  client     Client?     @relation(fields: [clientId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])
  assessment Assessment? @relation(fields: [assessmentId], references: [id])
}

model AccountActivationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CommunicationTestSend {
  id                String                      @id @default(uuid())
  templateKey       String
  recipientEmail    String
  providerMessageId String?
  status            CommunicationTestSendStatus
  errorMessage      String?                     @db.Text
  sentByUserId      String
  createdAt         DateTime                    @default(now())

  sentBy User @relation(fields: [sentByUserId], references: [id])

  @@index([createdAt])
  @@index([templateKey])
  @@index([sentByUserId])
}

model CommunicationBrandSettings {
  id                String   @id @default("default")
  primaryLogoUrl    String?
  secondaryLogoUrl  String?
  primaryColor      String   @default("#082F5B")
  secondaryColor    String   @default("#7D97AC")
  accentColor       String   @default("#2563EB")
  buttonPrimaryBg   String   @default("#082F5B")
  buttonPrimaryText String   @default("#FFFFFF")
  buttonSecondaryBg String @default("#F4F6F8")
  buttonSecondaryText String @default("#082F5B")
  fontFamilyHeading String   @default("Georgia, 'Times New Roman', serif")
  fontFamilyBody    String   @default("Arial, Helvetica, sans-serif")
  companyName       String   @default("Bobkat IT")
  productName       String   @default("StackScore")
  websiteUrl        String?
  supportEmail      String?
  supportPhone      String?
  address           String?  @db.Text
  copyrightText     String?
  footerTagline     String?
  socialLinks       Json     @default("[]")
  componentSettings Json     @default("{}")
  updatedAt         DateTime @updatedAt
  updatedByUserId   String?

  updatedBy User? @relation(fields: [updatedByUserId], references: [id])
}

model CommunicationTemplateVersion {
  id                String                             @id @default(uuid())
  templateKey       String
  versionNumber     Int
  status            CommunicationTemplateVersionStatus
  subject           String
  previewText       String                             @db.Text
  contentJson       Json
  sharedComponents  Json                               @default("[]")
  changeNotes       String?                            @db.Text
  publishedAt       DateTime?
  publishedByUserId String?
  createdByUserId   String
  createdAt         DateTime                           @default(now())
  updatedAt         DateTime                           @updatedAt

  publishedBy User? @relation("PublishedTemplateVersions", fields: [publishedByUserId], references: [id])
  createdBy   User  @relation("CreatedTemplateVersions", fields: [createdByUserId], references: [id])

  @@unique([templateKey, versionNumber])
  @@index([templateKey, status])
}

model CommunicationSampleProfile {
  id              String   @id @default(uuid())
  name            String
  templateKey     String?
  sampleDataJson  Json
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User @relation(fields: [createdByUserId], references: [id])

  @@index([templateKey])
  @@index([createdByUserId])
}

model TechnologyCategory {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  description  String?  @db.Text
  icon         String?
  displayOrder Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  technologies Technology[]
}

model Technology {
  id                 String                    @id @default(uuid())
  slug               String                    @unique
  name               String
  vendor             String
  productFamily      String
  categoryId         String
  summary            String                    @db.Text
  purpose            String                    @db.Text
  whySelected        String?                   @db.Text
  businessValue      String?                   @db.Text
  technicalOverview  String?                   @db.Text
  standardDeployment String?                   @db.Text
  supportScope       String?                   @db.Text
  limitations        String?                   @db.Text
  licensingNotes     String?                   @db.Text
  securityNotes      String?                   @db.Text
  operationalNotes   String?                   @db.Text
  stackLayer         String?
  standardStatus     TechnologyStandardStatus  @default(approved)
  lifecycleStatus    TechnologyLifecycleStatus @default(current)
  isFeatured         Boolean                   @default(false)
  isActive           Boolean                   @default(true)
  icon               String?
  websiteUrl         String?
  documentationUrl   String?
  relatedPlaybookCount Int                     @default(0)
  lastReviewedAt     DateTime?
  nextReviewAt       DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  category           TechnologyCategory          @relation(fields: [categoryId], references: [id])
  capabilities       TechnologyCapability[]
  products           TechnologyProduct[]
  businessOutcomes   TechnologyBusinessOutcome[]
  pillarMappings     TechnologyPillarMapping[]
  clientTechnologies ClientTechnology[]
}

model TechnologyCapability {
  id             String   @id @default(uuid())
  technologyId   String
  name           String
  description    String?  @db.Text
  capabilityType String?
  displayOrder   Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  technology Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@index([technologyId])
}

model TechnologyProduct {
  id                 String                    @id @default(uuid())
  technologyId       String
  name               String
  modelNumber        String?
  productType        String
  summary            String?                   @db.Text
  recommendedUseCase String?                   @db.Text
  environmentSize    String?
  lifecycleStatus    TechnologyLifecycleStatus @default(current)
  isPreferred        Boolean                   @default(false)
  specificationsJson Json?
  notes              String?                   @db.Text
  displayOrder       Int
  isActive           Boolean                   @default(true)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  technology         Technology         @relation(fields: [technologyId], references: [id], onDelete: Cascade)
  clientTechnologies ClientTechnology[]

  @@index([technologyId])
}

model TechnologyBusinessOutcome {
  id           String   @id @default(uuid())
  technologyId String
  name         String
  description  String?  @db.Text
  displayOrder Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  technology Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@index([technologyId])
}

model TechnologyPillarMapping {
  id               String                           @id @default(uuid())
  technologyId     String
  pillarCode       String
  relationshipType TechnologyPillarRelationshipType
  explanation      String?                          @db.Text
  createdAt        DateTime                         @default(now())
  updatedAt        DateTime                         @updatedAt

  technology Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@unique([technologyId, pillarCode, relationshipType])
  @@index([technologyId])
  @@index([pillarCode])
}

model ClientTechnology {
  id                     String                           @id @default(uuid())
  clientId               String
  technologyId           String
  technologyProductId    String?
  displayName            String?
  businessPurpose        String?                          @db.Text
  deploymentStatus       ClientTechnologyDeploymentStatus @default(active)
  alignmentStatus        ClientTechnologyAlignmentStatus  @default(unassessed)
  healthStatus           ClientTechnologyHealthStatus     @default(unknown)
  lifecycleStatus        TechnologyLifecycleStatus        @default(current)
  quantity               Int?
  quantityUnit           String?
  coverageNotes          String?                          @db.Text
  managedBy              ManagedByType                    @default(unknown)
  vendorAccountReference String?
  implementationDate     DateTime?
  renewalDate            DateTime?
  reviewDate             DateTime?
  ownerName              String?
  technicalOwnerName     String?
  exceptionReason        String?                          @db.Text
  notes                  String?                          @db.Text
  isActive               Boolean                          @default(true)
  createdAt              DateTime                         @default(now())
  updatedAt              DateTime                         @updatedAt

  client            Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  technology        Technology         @relation(fields: [technologyId], references: [id])
  technologyProduct TechnologyProduct? @relation(fields: [technologyProductId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([technologyId])
}

model TechnologySnapshotLead {
  id                String                        @id @default(uuid())
  contactName       String
  companyName       String
  email             String
  phone             String?
  industry          String
  companySize       String?
  itManagementModel SnapshotItManagementModel
  answers           Json
  totalScore        Int
  classification    String
  lowestPillars     Json
  status            TechnologySnapshotLeadStatus  @default(new)
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([email])
}
