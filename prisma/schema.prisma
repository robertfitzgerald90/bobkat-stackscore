model ClientBillingProfile {
  id                      String   @id @default(uuid())
  clientId                String   @unique
  stripeCustomerId        String?  @unique
  billingCompanyName      String?
  billingEmail            String?
  billingPhone            String?
  addressLine1            String?
  addressLine2            String?
  city                    String?
  state                   String?
  postalCode              String?
  country                 String?  @default("US")
  paymentTermsDays        Int      @default(30)
  defaultBillingContactId String?
  taxExempt               Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
}

model Invoice {
  id                      String              @id @default(uuid())
  clientId                String
  invoiceNumber           String              @unique
  status                  InvoiceStatus       @default(draft)
  sourceType              InvoiceSourceType   @default(manual)
  documentType            InvoiceDocumentType @default(standard)
  title                   String?
  clientDescription       String?             @db.Text
  expirationDate          DateTime?
  shippingCents           Int                 @default(0)
  contingencyCents        Int                 @default(0)
  budgetaryOptionsJson    Json?
  currency                String              @default("usd")
  subtotalCents           Int                 @default(0)
  discountCents           Int                 @default(0)
  taxCents                Int                 @default(0)
  creditCents             Int                 @default(0)
  depositAppliedCents     Int                 @default(0)
  totalCents              Int                 @default(0)
  amountPaidCents         Int                 @default(0)
  balanceDueCents         Int                 @default(0)
  issueDate               DateTime?
  dueDate                 DateTime?
  paidAt                  DateTime?
  paymentTermsDays        Int                 @default(30)
  clientNotes             String?             @db.Text
  internalNotes           String?             @db.Text
  billToName              String?
  billToEmail             String?
  billToPhone             String?
  billToAddressJson       Json?
  billingContactId        String?
  tipId                   String?
  projectId               String?
  depositId               String?
  assessmentPurchaseId    String?             @unique
  stripeCheckoutSessionId String?             @unique
  stripePaymentIntentId   String?
  stripePaymentLinkUrl    String?
  onlinePaymentEnabled    Boolean             @default(true)
  createdByUserId         String
  voidedAt                DateTime?
  voidedByUserId          String?
  voidReason              String?             @db.Text
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  client              Client                     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  billingContact      ClientContact?             @relation("InvoiceBillingContact", fields: [billingContactId], references: [id], onDelete: SetNull)
  tip                 TechnologyImprovementPlan? @relation(fields: [tipId], references: [id], onDelete: SetNull)
  project             Project?                   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  deposit             BillingDeposit?            @relation(fields: [depositId], references: [id], onDelete: SetNull)
  assessmentPurchase  AssessmentPurchase?        @relation(fields: [assessmentPurchaseId], references: [id], onDelete: SetNull)
  createdBy           User                       @relation("InvoiceCreatedBy", fields: [createdByUserId], references: [id])
  lineItems           InvoiceLineItem[]
  deliveries          InvoiceDelivery[]
  paymentApplications PaymentApplication[]
  auditEvents         BillingAuditEvent[]

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@index([tipId])
}

model InvoiceLineItem {
  id                 String              @id @default(uuid())
  invoiceId          String
  sortOrder          Int                 @default(0)
  itemName           String?
  description        String
  unit               String?
  quantity           Decimal             @default(1) @db.Decimal(12, 4)
  unitPriceCents     Int
  amountCents        Int
  category           InvoiceLineCategory @default(other)
  lineKind           InvoiceLineKind     @default(one_time)
  taxable            Boolean             @default(false)
  catalogSourceType  String?
  catalogSourceId    String?
  servicePeriodStart DateTime?
  servicePeriodEnd   DateTime?
  internalCostCents  Int?
  clientNote         String?             @db.Text
  recommendationId   String?
  projectId          String?
  recurringServiceId String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  invoice          Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  project          Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  recurringService RecurringService? @relation(fields: [recurringServiceId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
}

model BillingPayment {
  id                    String                  @id @default(uuid())
  clientId              String
  amountCents           Int
  currency              String                  @default("usd")
  paymentDate           DateTime
  method                BillingPaymentMethod
  status                BillingPaymentStatus    @default(pending)
  processor             BillingPaymentProcessor @default(manual)
  transactionReference  String?
  stripeSessionId       String?                 @unique
  stripePaymentIntentId String?
  stripeChargeId        String?
  processingFeeCents    Int                     @default(0)
  unappliedAmountCents  Int                     @default(0)
  notes                 String?                 @db.Text
  refundStatus          String?
  recordedByUserId      String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  client       Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recordedBy   User?                @relation("BillingPaymentRecordedBy", fields: [recordedByUserId], references: [id], onDelete: SetNull)
  applications PaymentApplication[]
  auditEvents  BillingAuditEvent[]

  @@index([clientId])
  @@index([status])
  @@index([paymentDate])
}

model PaymentApplication {
  id           String   @id @default(uuid())
  paymentId    String
  invoiceId    String
  appliedCents Int
  createdAt    DateTime @default(now())

  payment BillingPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([paymentId, invoiceId])
  @@index([invoiceId])
}

model BillingDeposit {
  id                 String               @id @default(uuid())
  clientId           String
  depositType        BillingDepositType
  status             BillingDepositStatus @default(not_requested)
  label              String
  amountCents        Int?
  percentage         Decimal?             @db.Decimal(5, 2)
  currency           String               @default("usd")
  tipId              String?
  projectId          String?
  invoiceId          String?
  appliedToInvoiceId String?
  appliedAt          DateTime?
  requestedAt        DateTime?
  paidAt             DateTime?
  notes              String?              @db.Text
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  client           Client                     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tip              TechnologyImprovementPlan? @relation(fields: [tipId], references: [id], onDelete: SetNull)
  project          Project?                   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectRequiring Project?                   @relation("ProjectRequiredDeposit")
  invoices         Invoice[]

  @@index([clientId])
  @@index([status])
  @@index([tipId])
}

model RecurringService {
  id                    String                 @id @default(uuid())
  clientId              String
  serviceName           String
  description           String?                @db.Text
  quantity              Decimal                @default(1) @db.Decimal(12, 4)
  unitPriceCents        Int
  billingFrequency      BillingFrequency       @default(monthly)
  customFrequencyDays   Int?
  startDate             DateTime?
  nextBillingDate       DateTime?
  renewalDate           DateTime?
  minimumTermMonths     Int?
  autoRenew             Boolean                @default(true)
  paymentMethodStatus   String?
  relatedTechnology     String?
  relatedAgreement      String?
  status                RecurringServiceStatus @default(draft)
  lastInvoiceDate       DateTime?
  internalCostCents     Int?
  internalMarginPercent Decimal?               @db.Decimal(5, 2)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  client        Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lineItems     InvoiceLineItem[]
  subscriptions Subscription[]

  @@index([clientId])
  @@index([status])
  @@index([nextBillingDate])
}

model Subscription {
  id                       String             @id @default(uuid())
  clientId                 String
  recurringServiceId       String?
  provider                 BillingProvider    @default(stripe)
  providerCustomerId       String
  providerSubscriptionId   String             @unique
  providerPriceId          String
  providerProductId        String?
  serviceType              ServiceType
  billingInterval          BillingInterval    @default(month)
  amountCents              Int
  currency                 String             @default("usd")
  status                   SubscriptionStatus @default(incomplete)
  rawStatus                String
  currentPeriodStart       DateTime?
  currentPeriodEnd         DateTime?
  cancelAtPeriodEnd        Boolean            @default(false)
  canceledAt               DateTime?
  endedAt                  DateTime?
  trialStart               DateTime?
  trialEnd                 DateTime?
  latestInvoiceProviderId  String?
  lastPaymentAt            DateTime?
  paymentFailedAt          DateTime?
  paymentActionRequiredAt  DateTime?
  lastStripeEventCreatedAt DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  client               Client                       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recurringService     RecurringService?            @relation(fields: [recurringServiceId], references: [id], onDelete: SetNull)
  invoices             SubscriptionInvoice[]
  paymentAttempts      SubscriptionPaymentAttempt[]
  vcioOnboarding       VcioOnboarding?
  vcioQuarterlyReviews VcioQuarterlyReview[]

  @@index([clientId])
  @@index([serviceType])
  @@index([status])
  @@index([providerCustomerId])
  @@index([currentPeriodEnd])
  @@index([latestInvoiceProviderId])
}

model SubscriptionInvoice {
  id                       String                @id @default(uuid())
  subscriptionId           String
  clientId                 String
  provider                 BillingProvider       @default(stripe)
  providerInvoiceId        String                @unique
  providerPaymentIntentId  String?
  number                   String?
  amountDueCents           Int                   @default(0)
  amountPaidCents          Int                   @default(0)
  currency                 String                @default("usd")
  status                   String
  invoiceDate              DateTime?
  dueDate                  DateTime?
  paidAt                   DateTime?
  attemptCount             Int                   @default(0)
  nextPaymentAttemptAt     DateTime?
  lastPaymentAttemptAt     DateTime?
  lastPaymentAttemptStatus PaymentAttemptStatus?
  failureCode              String?
  failureDeclineCode       String?
  failureMessage           String?               @db.Text
  paymentMethodBrand       String?
  paymentMethodLast4       String?
  paymentMethodExpMonth    Int?
  paymentMethodExpYear     Int?
  hostedInvoiceUrl         String?               @db.Text
  invoicePdfUrl            String?               @db.Text
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  subscription    Subscription                 @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  client          Client                       @relation(fields: [clientId], references: [id], onDelete: Cascade)
