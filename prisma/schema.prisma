  startedAt       DateTime?
  completedAt     DateTime?

  createdBy  User                   @relation("CampaignCreatedBy", fields: [createdByUserId], references: [id])
  recipients CampaignRecipient[]
  events     CampaignEvent[]
  messages   CommunicationMessage[]

  @@index([status])
  @@index([createdAt])
  @@index([createdByUserId])
}

model CampaignRecipient {
  id                     String    @id @default(uuid())
  campaignId             String
  prospectId             String
  clientId               String?
  userId                 String?
  assessmentId           String?
  communicationMessageId String?   @unique
  invitedAt              DateTime?
  openedAt               DateTime?
  clickedAt              DateTime?
  assessmentStartedAt    DateTime?
  assessmentCompletedAt  DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  campaign   CommunicationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  prospect   Prospect              @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  client     Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  user       User?                 @relation("CampaignRecipientUser", fields: [userId], references: [id], onDelete: SetNull)
  assessment Assessment?           @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  message    CommunicationMessage? @relation(fields: [communicationMessageId], references: [id], onDelete: SetNull)
  events     CampaignEvent[]

  @@unique([campaignId, prospectId])
  @@index([campaignId])
  @@index([prospectId])
  @@index([clientId])
}

model CampaignEvent {
  id           String   @id @default(uuid())
  campaignId   String
  eventType    String
  title        String
  description  String?  @db.Text
  occurredAt   DateTime @default(now())
  metadataJson Json?
  actorUserId  String?
  recipientId  String?

  campaign  CommunicationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actor     User?                 @relation("CampaignEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  recipient CampaignRecipient?    @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([campaignId, occurredAt])
  @@index([eventType])
}

model CommunicationWorkflowSettings {
  id                                 String                   @id @default("default")
  defaultSenderEmail                 String?
  defaultReplyToEmail                String?
  recipientDefaultsJson              Json                     @default("{}")
  ctaDestinationsJson                Json                     @default("{}")
  internalNotificationEmailsJson     Json                     @default("[]")
  proposalApprovalNotificationEmail  String                   @default("bobby@bobkatit.com")
  quarterlyReviewDaysAfterAssessment Int                      @default(90)
  quarterlyReviewLeadDays            Int                      @default(14)
  attachmentDefaultsJson             Json                     @default("{}")
  projectCompletionDefault           NotificationDeliveryMode @default(automatic)
  updatedByUserId                    String?
  updatedAt                          DateTime                 @updatedAt
}

model ClientContact {
  id                           String   @id @default(uuid())
  clientId                     String
  name                         String
  email                        String
  phone                        String?
  title                        String?
  rolesJson                    Json     @default("[]")
  communicationPreferencesJson Json     @default("{}")
  isActive                     Boolean  @default(true)
  userId                       String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  client                   Client                      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user                     User?                       @relation(fields: [userId], references: [id], onDelete: SetNull)
  approvedTips             TechnologyImprovementPlan[] @relation("TipApprovedByContact")
  approvedRoadmapPhases    ClientRoadmapPhase[]        @relation("RoadmapPhaseApprovedByContact")
  approvedPhaseProposals   PhaseProposal[]             @relation("PhaseProposalApprovedByContact")
  invoicesAsBillingContact Invoice[]                   @relation("InvoiceBillingContact")

  @@unique([clientId, email])
  @@index([clientId])
  @@index([email])
}

model CommunicationQueueItem {
  id                     String                   @id @default(uuid())
  workflowKey            String
  templateKey            String
  status                 CommunicationQueueStatus @default(pending_review)
  clientId               String?
  prospectId             String?
  assessmentId           String?
  tipId                  String?
  projectIdsJson         Json?
  recipientSelectionJson Json                     @default("{}")
  payloadJson            Json?
  scheduledFor           DateTime?
  reviewRequired         Boolean                  @default(true)
  autoSend               Boolean                  @default(false)
  createdByUserId        String?
  approvedByUserId       String?
  sentAt                 DateTime?
  dismissedAt            DateTime?
  failureReason          String?                  @db.Text
  metadataJson           Json?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  client     Client?                    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  prospect   Prospect?                  @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  assessment Assessment?                @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  tip        TechnologyImprovementPlan? @relation(fields: [tipId], references: [id], onDelete: SetNull)
  createdBy  User?                      @relation("QueueCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedBy User?                      @relation("QueueApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  messages   CommunicationMessage[]

  @@index([status])
  @@index([clientId])
  @@index([scheduledFor])
  @@index([workflowKey])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model QuarterlyReviewReminder {
  id                        String                        @id @default(uuid())
  clientId                  String
  dueAt                     DateTime
  status                    QuarterlyReviewReminderStatus @default(pending)
  delayedUntil              DateTime?
  scheduledFor              DateTime?
  dismissedAt               DateTime?
  dismissReason             String?                       @db.Text
  lastAssessmentCompletedAt DateTime?
  queueItemId               String?
  idempotencyKey            String                        @unique
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@index([dueAt])
}

