model SubscriptionPaymentAttempt {
  id                      String               @id @default(uuid())
  subscriptionId          String
  subscriptionInvoiceId   String?
  clientId                String
  provider                BillingProvider      @default(stripe)
  providerEventId         String?              @unique
  providerInvoiceId       String
  providerPaymentIntentId String?
  providerChargeId        String?
  serviceType             ServiceType
  status                  PaymentAttemptStatus
  attemptDate             DateTime
  invoiceNumber           String?
  amountCents             Int                  @default(0)
  currency                String               @default("usd")
  failureCode             String?
  failureDeclineCode      String?
  failureMessage          String?              @db.Text
  attemptCount            Int                  @default(0)
  nextPaymentAttemptAt    DateTime?
  paymentMethodBrand      String?
  paymentMethodLast4      String?
  paymentMethodExpMonth   Int?
  paymentMethodExpYear    Int?
  hostedInvoiceUrl        String?              @db.Text
  stripeCustomerId        String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  subscription        Subscription         @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionInvoice SubscriptionInvoice? @relation(fields: [subscriptionInvoiceId], references: [id], onDelete: SetNull)
  client              Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([provider, providerInvoiceId, attemptCount, status])
  @@index([clientId])
  @@index([subscriptionId])
  @@index([subscriptionInvoiceId])
  @@index([status])
  @@index([attemptDate])
  @@index([serviceType])
  @@index([nextPaymentAttemptAt])
