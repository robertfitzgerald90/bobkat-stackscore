  clientId     String?
  invoiceId    String?
  paymentId    String?
  action       BillingAuditAction
  actorUserId  String?
  metadataJson Json?
  createdAt    DateTime           @default(now())

  invoice Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  payment BillingPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  actor   User?           @relation("BillingAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([invoiceId])
  @@index([action])
  @@index([createdAt])
}

model StripeWebhookEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  eventType   String
  processedAt DateTime @default(now())
  payloadJson Json?

  @@index([eventType])
}
