# Database
DATABASE_URL="postgresql://user:password@host:5433/stackscore"

# Auth.js (required)
AUTH_SECRET="generate-a-secure-random-string-for-production"
AUTH_URL="http://localhost:3000"

# Runtime (optional)
NODE_ENV="development"

# Seed (optional — defaults to ChangeMe123!)
SEED_ADMIN_PASSWORD="ChangeMe123!"

# App (optional)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# PDF report branding (optional)
BOBKAT_IT_WEBSITE="www.bobkatit.com"
BOBKAT_IT_EMAIL="info@bobkatit.com"
BOBKAT_IT_PHONE=""
