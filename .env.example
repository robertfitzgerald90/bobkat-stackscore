# =============================================================================
# BobKat StackScore — Environment Template
# =============================================================================
# LOCAL:  Copy this file to `.env` and use your LAN/home PostgreSQL.
# VERCEL: Set the PRODUCTION values in the Vercel dashboard (never commit them).
# =============================================================================

# -----------------------------------------------------------------------------
# LOCAL DEVELOPMENT — PostgreSQL on your network (e.g. 192.168.x.x)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://stackscore_user:YOUR_PASSWORD@192.168.1.106:5433/stackscore"

# -----------------------------------------------------------------------------
# VERCEL PRODUCTION — Neon (set in Vercel dashboard only, not in .env)
# Example shape (use your Neon console connection string):
# DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
# -----------------------------------------------------------------------------

# Auth.js (required)
AUTH_SECRET="generate-a-secure-random-string-at-least-32-chars"
# Local:
AUTH_URL="http://localhost:3000"
# Vercel production:
# AUTH_URL="https://stackscore.bobkatit.com"

NODE_ENV="development"

SEED_ADMIN_PASSWORD="ChangeMe123!"

# Acme Foundation customer portal review (development only — npm run seed:demo-client)
# DEMO_CLIENT_EMAIL="acme.foundation.demo@bobkatit.com"
# DEMO_CLIENT_PASSWORD="AcmeDemo2026!"
# ALLOW_DEMO_SEED=true  # Required to run demo seed when NODE_ENV=production

# Local:
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Vercel production:
# NEXT_PUBLIC_APP_URL="https://stackscore.bobkatit.com"

BOBKAT_IT_WEBSITE="www.bobkatit.com"
BOBKAT_IT_EMAIL="info@bobkatit.com"
BOBKAT_IT_PHONE=""

# Technology Snapshot results CTA (optional override; default is bobkatit.com/technology-assessment)
# NEXT_PUBLIC_ASSESSMENT_PURCHASE_URL="https://bobkatit.com/technology-assessment"

# Stripe (Technology Assessment checkout)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_ASSESSMENT_PRICE_ID="price_..."

# Email (Resend — activation links after purchase)
RESEND_API_KEY="re_..."
EMAIL_FROM="StackScore <onboarding@bobkatit.com>"
# Optional absolute base for email image assets (defaults to NEXT_PUBLIC_APP_URL)
# EMAIL_ASSET_BASE_URL="https://app.bobkatit.com"

# Test-data cleanup (npm run cleanup:test-data)
# Comma-separated; admin@bobkatit.com, technician@bobkatit.com, bobby@bobkatit.com are always protected
PROTECTED_USER_EMAILS="bobby@bobkatit.com"
# PROTECTED_CLIENT_EMAILS="real-client@example.com"
# PROTECTED_SNAPSHOT_LEAD_EMAILS="real-lead@company.com"
# TEST_SNAPSHOT_EMAIL_PATTERNS="bobbytest%@bobkatit.com,%test%@bobkatit.com"

# Customer portal — Microsoft Bookings (opens in new tab from Support page)
# NEXT_PUBLIC_BOOKING_URL="https://outlook.office.com/book/..."
